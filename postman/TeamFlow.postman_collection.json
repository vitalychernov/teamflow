{
  "info": {
    "name": "TeamFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.smith@teamflow.com\",\n  \"password\": \"demo123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Get all projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects?page=0&size=10&sortBy=createdAt&direction=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"],
              "query": [
                { "key": "page",      "value": "0" },
                { "key": "size",      "value": "10" },
                { "key": "sortBy",    "value": "createdAt" },
                { "key": "direction", "value": "desc" },
                { "key": "keyword",   "value": "", "disabled": true }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Get project by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/projects/1",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/projects",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Project\",\n  \"description\": \"Project description\"\n}"
            }
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/projects/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/projects/1",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get tasks for project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/1/tasks?page=0&size=10&sortBy=createdAt&direction=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "1", "tasks"],
              "query": [
                { "key": "page",       "value": "0" },
                { "key": "size",       "value": "10" },
                { "key": "sortBy",     "value": "createdAt" },
                { "key": "direction",  "value": "desc" },
                { "key": "status",     "value": "TODO",   "disabled": true },
                { "key": "priority",   "value": "HIGH",   "disabled": true },
                { "key": "assigneeId", "value": "2",      "disabled": true }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Create task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/projects/1/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Task\",\n  \"description\": \"Task description\",\n  \"status\": \"TODO\",\n  \"priority\": \"MEDIUM\",\n  \"assigneeId\": 2\n}"
            }
          }
        },
        {
          "name": "Get task by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tasks/1",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Update task",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/tasks/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Task\",\n  \"description\": \"Updated description\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"HIGH\",\n  \"assigneeId\": 2\n}"
            }
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/tasks/1",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get users (assignee dropdown)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get all users (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/users?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    }
  ]
}
